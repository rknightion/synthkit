# Scratch — plans, specs, design notes. NEVER committed (working style: scratch is disposable).
docs/superpowers/
docs/scratch/
# Host-local runtime state (seed from control-state.example.json)
control-state.json
control-state-data/

# Host-local blueprint staging dir (custom uploads + git-fetched sources + boot manifest);
# default BLUEPRINT_DATA_DIR. Runtime state — never committed (in compose this lives on /data).
/data/

# Secrets / local config
.env
*.env.local

# Forbidden-words guard: the real customer/deployment term list (the credential-shape layer is
# committed in scripts/forbidden-words.sh; the deployment terms live ONLY here + the CI secret
# $FORBIDDEN_WORDS_PATTERN — NEVER committed). See scripts/forbidden-words.local.example.
scripts/forbidden-words.local

# Release-time artifacts (generated by `make notices`/`make sbom`; attached to the GitHub Release).
/THIRD_PARTY_NOTICES.md
/dist/

# Pinned CI tooling installed on demand; gcx dashboard snapshot PNGs; docs-site build output.
/.tools/
/snapshots/
/site/

# Build outputs — binaries only, never source. NOTE: anchored with a leading `/` (or a full path)
# so they match the built BINARY, NOT the `cmd/<name>/` SOURCE directory of the same name.
/synthkit
/synthkit-control-dash
/sm-provision
/skcapture
/skforge
/synthkit-dash
/cmd/synthkit/synthkit
/cmd/synthkit-control-dash/synthkit-control-dash
/cmd/sm-provision/sm-provision
/cmd/skcapture/skcapture
/cmd/skforge/skforge
/cmd/synthkit-dash/synthkit-dash
*.exe
*.test
*.out

# UI (if a node-based control UI is ported)
node_modules/

# OS
.DS_Store

# brainstorming visual companion scratch
.superpowers/

# Local self-signed control-plane TLS material (generated; never committed)
/tls/
