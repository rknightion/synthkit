        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Current state",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "Query",
                      "group": "yesoreyeram-infinity-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "synthkit (Infinity)"
                      },
                      "spec": {
                        "columns": [
                          {
                            "selector": "volume_multiplier",
                            "text": "Volume ×",
                            "type": "number"
                          },
                          {
                            "selector": "peak_rps_per_env",
                            "text": "Peak RPS/env",
                            "type": "number"
                          },
                          {
                            "selector": "platform_call_fraction",
                            "text": "Platform fraction",
                            "type": "number"
                          },
                          {
                            "selector": "rum_multiplier",
                            "text": "RUM ×",
                            "type": "number"
                          },
                          {
                            "selector": "series_cap",
                            "text": "Series cap",
                            "type": "number"
                          }
                        ],
                        "format": "table",
                        "parser": "backend",
                        "refId": "A",
                        "source": "url",
                        "type": "json",
                        "url": "/control/state",
                        "url_options": {
                          "method": "GET"
                        }
