# synthkit configuration — copy to .env and fill in. DRY_RUN defaults to TRUE:
# pushing live is always an explicit opt-in (set DRY_RUN=false).
#
# IMPORTANT: keep comments on their OWN line. Docker Compose's env_file does NOT strip inline
# `value # comment` (it becomes part of the value) — so never put a comment after a value here.

# ── Synthetic data sinks ──
# One CAP token (metrics:write, logs:write, traces:write, profiles:write) covers all synthetic sinks.
# GC_PROM_RW e.g. https://prometheus-prod-XX-<region>.grafana.net/api/prom/push  (GC_PROM_USER = Mimir id)
# GC_OTLP_ENDPOINT e.g. https://otlp-gateway-<region>.grafana.net/otlp           (GC_OTLP_USER = stack id)
# GC_LOKI e.g. https://logs-prod-XXX.grafana.net/loki/api/v1/push                (GC_LOKI_USER = Loki id)
GC_TOKEN=
GC_PROM_RW=
GC_PROM_USER=
GC_OTLP_ENDPOINT=
GC_OTLP_USER=
GC_LOKI=
GC_LOKI_USER=
GC_PROFILES_URL=
GC_PROFILES_USER=

# Optional — Faro/RUM (app + web_service workloads with a frontend/rum_faro node). Absent = RUM disabled.
# GC_FARO_COLLECTOR e.g. https://faro-collector-<region>.grafana.net/collect/<app-key>
GC_FARO_COLLECTOR=
GC_FARO_APP_KEY=

# ── Behaviour ──
# DRY_RUN: flip to false to push live. TICK_DEFAULT: master-clock cadence. SERIES_CAP: optional
# global per-push series backstop (empty = unlimited). BLUEPRINTS: dir (every *.yaml is loaded).
# JSON_HTTP_ADDR: the address the app BINDS for the control plane + Infinity JSON host
# (/control/ui for the operator UI). In Docker keep this 0.0.0.0:8088 — the process must bind
# all interfaces INSIDE the container for Docker's port mapping to reach it; host exposure is
# restricted separately by SYNTHKIT_BIND (below). A non-Docker direct run defaults to
# 127.0.0.1:8088 (loopback-safe). Either way, mutations are unauthenticated unless CONTROL_TOKEN is set.
DRY_RUN=true
TICK_DEFAULT=5s
SERIES_CAP=
BLUEPRINTS=./blueprints
JSON_HTTP_ADDR=0.0.0.0:8088
CONFIG_SNAPSHOT_PATH=./control-state.json
# CONTROL_TOKEN: HTTP Basic password (username "control") for POST /control/* (empty = auth disabled)
CONTROL_TOKEN=
# TICK_TIMEOUT: optional per-blueprint per-tick backstop in seconds. Empty/0 = disabled (the per-sink
# 15s HTTP timeouts already bound hung pushes); set >0 only as a coarse whole-tick safety net.
TICK_TIMEOUT=

# ── External / custom blueprint sources ──
# Persisted staging dir for custom/git blueprints (under the /data volume in compose).
BLUEPRINT_DATA_DIR=./data/blueprints
# Git source poll interval in seconds for "update available" detection (0 = off, detect-and-notify only).
GIT_POLL_INTERVAL=0
# Default git token (HTTPS PAT) for private blueprint repos whose source config leaves token_env_var empty;
# leave blank for public repos. Per-source custom token_env_var names are operator-defined and not tracked here.
GIT_TOKEN=

# ── Decoupled delivery queue (internal/sink/queue) ──
# SEND_SHARDS: parallel shard workers per sink (default 8).
SEND_SHARDS=8
# SEND_BATCH_MAX: max series per flush batch (default 5000).
SEND_BATCH_MAX=5000
# SEND_BATCH_DEADLINE: max age before a partial batch is flushed (Go duration; default 5s).
SEND_BATCH_DEADLINE=5s
# SEND_QUEUE_CAPACITY: ring-buffer depth in series slots before backpressure (default 500000;
# burst headroom for many simultaneous clusters — RAM is consumed only when the buffer actually
# fills under backpressure, so this is cheap headroom; raise further for very high cluster counts).
SEND_QUEUE_CAPACITY=500000
# SEND_DRAIN_DEADLINE: graceful-shutdown drain budget (Go duration; default 30s).
SEND_DRAIN_DEADLINE=30s

# Published GHCR image tag pulled by docker-compose.yml. Compose-only (the app ignores it).
# `latest` = the last tagged release (only exists once the first release is cut). Set `main` to
# track the bleeding-edge default-branch build, or `vX.Y.Z` to pin a release. Ignored when
# building locally via docker-compose.build.yml.
SYNTHKIT_IMAGE_TAG=latest

# Host interface the compose publishes :8088 on (operator UI + Infinity datasource). Compose-only
# (the app ignores it). Default in docker-compose.yml is loopback (127.0.0.1) — SAFE: the control
# plane is UNAUTHENTICATED and write-capable. Set 0.0.0.0 (or a specific tailscale/LAN IP) ONLY on a
# trusted network when Grafana / another host must reach it; otherwise SSH-tunnel to localhost:8088.
# Front the bind with `tailscale serve` for a browser-trusted HTTPS endpoint; Grafana Cloud reaches
# it privately via the user-configured PDC Tailscale connection (adds a tailnet auth key).
SYNTHKIT_BIND=127.0.0.1

# ── Self-profiling (Pyroscope) — the generator's OWN process telemetry ──
# SEPARATE data path: ships the synthkit binary's continuous profiles to a DIFFERENT Grafana Cloud
# stack via its own credential triplet (NEVER GC_TOKEN). It is just another self-obs signal, so it
# has NO master flag of its own — it follows SELFOBS_ENABLED and is suppressed under DRY_RUN; set the
# GC_PYROSCOPE_* triplet below to ship profiles (empty triplet = profiling no-ops even with self-obs on).
# GC_PYROSCOPE_URL e.g. https://profiles-prod-XXX.grafana.net (GC_PYROSCOPE_USER = Profiles instance id).
# PYROSCOPE_MUTEX_FRACTION / _BLOCK_RATE: 0 = off; 5 = high-fidelity, fine for a lab app.
GC_PYROSCOPE_URL=
GC_PYROSCOPE_USER=
GC_PYROSCOPE_PASSWORD=
PYROSCOPE_TAGS=
PYROSCOPE_MUTEX_FRACTION=5
PYROSCOPE_BLOCK_RATE=5

# ── Self-observability (OTLP) — the generator's OWN operability telemetry ──
# Push RED metrics on the synthetic pipeline + Go runtime metrics + per-tick traces + the
# operational log stream, over a SINGLE OTLP endpoint. SEPARATE data path: ships to a DIFFERENT
# stack via its own credential triplet (NEVER GC_TOKEN). Off by default; decoupled from DRY_RUN.
# GC_SELF_OTLP_ENDPOINT = base OTLP gateway URL (…/otlp); GC_SELF_OTLP_USER = the self-obs stack id.
SELFOBS_ENABLED=false
GC_SELF_OTLP_ENDPOINT=
GC_SELF_OTLP_USER=
GC_SELF_OTLP_PASSWORD=
SELFOBS_TAGS=
# GC_SELF_GRAFANA_URL = staff Grafana base URL (e.g. https://your-stack.grafana.net) — enables control-UI deep-links to the self-obs dashboard; leave empty to hide them.
GC_SELF_GRAFANA_URL=
# SELFOBS_METRIC_INTERVAL = self-obs METRIC flush cadence (Go duration; traces/logs unaffected). Default 15s.
SELFOBS_METRIC_INTERVAL=15s

# ── Synthetic Monitoring provisioner (cmd/sm-provision only — NOT the emitter) ──
# `go run ./cmd/sm-provision` registers the offline probe + checks so the GC Synthetic Monitoring
# app populates with NO real probe execution. Needs the SM API token (NOT GC_TOKEN).
# GC_SM_URL e.g. https://synthetic-monitoring-api-<region>.grafana.net
GC_SM_URL=
GC_SM_TOKEN=

# ── Fleet Management (fake-collector registration via the FM connect API) ──
# GC_FM_STACK_ID = FM basic-auth username = Grafana Cloud STACK ID (NOT GC_PROM_USER).
# GC_FM_URL e.g. https://fleet-management-prod-0NN.grafana.net ; GC_FM_TOKEN = CAP with fleet-management:write.
GC_FM_URL=
GC_FM_STACK_ID=
GC_FM_TOKEN=

# ── Sigil AI Observability ingest (the aiagent workload's generation/conversation lane) ──
# Optional: empty ⇒ the sigil generation lane no-ops (gen_ai traces+metrics still flow via GC_OTLP_*/GC_PROM_*).
# GC_SIGIL_ENDPOINT e.g. https://sigil-prod-gb-south-1.grafana.net (base; /api/v1/...:export is appended).
# Auth is HTTP Basic base64(GC_SIGIL_TENANT_ID:GC_SIGIL_TOKEN). GC_SIGIL_TENANT_ID = the stack/tenant id
# (NOT GC_PROM_USER); GC_SIGIL_TOKEN = a CAP with the sigil ingest scope (NOT GC_TOKEN). Point GC_OTLP_*/
# GC_PROM_* at the SAME stack so the gen_ai traces+metrics correlate with the conversations.
GC_SIGIL_ENDPOINT=
GC_SIGIL_TENANT_ID=
GC_SIGIL_TOKEN=

# ── Container runtime hint (optional) ──
# Set non-empty when running inside a container so the control-plane bind warning knows the
# 0.0.0.0 bind is expected (real exposure is the host port mapping). Auto-detected via
# /.dockerenv when unset; docker-compose can leave this blank.
SYNTHKIT_IN_CONTAINER=
